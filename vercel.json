{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api-server/index.mjs"
    },
    {
      "source": "/(.*)",
      "destination": "/kelulusan/$1"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/kelulusan/",
      "permanent": true
    }
  ]
}
